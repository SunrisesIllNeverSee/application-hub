{
  "manifest_version": 3,
  "name": "Application Hub",
  "version": "0.1.0",
  "description": "Pre-fill accelerator and grant applications from your answer bank.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://ycombinator.com/*",
    "https://www.ycombinator.com/*",
    "https://apply.techstars.com/*",
    "https://speedrun.a16z.com/*",
    "https://500.co/*",
    "https://apply.solofounders.com/*",
    "https://*.acceleratorapp.co/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://ycombinator.com/apply*",
        "https://www.ycombinator.com/apply*",
        "https://apply.techstars.com/*",
        "https://speedrun.a16z.com/apply*",
        "https://500.co/*/apply*",
        "https://apply.solofounders.com/*",
        "https://*.acceleratorapp.co/application/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Application Hub",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
