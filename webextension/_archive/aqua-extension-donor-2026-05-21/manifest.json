{
  "manifest_version": 3,
  "name": "AQUA Canonical Hub",
  "version": "0.1.0",
  "description": "Capture application questions, match answers, and pre-fill portals through AQUA.",
  "permissions": ["storage", "activeTab", "downloads", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AQUA"
  }
}
