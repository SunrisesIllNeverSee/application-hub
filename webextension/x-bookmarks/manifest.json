{
  "manifest_version": 3,
  "name": "X Bookmarks Export",
  "version": "0.1.0",
  "description": "Export X / Twitter bookmarks into Markdown or JSON for local sorting in VS Code.",
  "permissions": [
    "activeTab",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/i/bookmarks*",
        "https://twitter.com/i/bookmarks*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "X Bookmarks Export",
    "default_popup": "popup.html"
  }
}
